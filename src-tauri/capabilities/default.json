{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "fs:read-all",
      "allow": [{ "path": "**" }]
    },
    "fs:allow-read-dir",
    "fs:allow-size",
    "dialog:default"
  ]
}